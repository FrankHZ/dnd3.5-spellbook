{
  "name": "dnd3.5-spellbook-server",
  "version": "1.0.0",
  "description": "A modern **Dungeons & Dragons 3.5 spellbook web application** built with a **React + Express** stack, powered by a legacy SQLite dataset and extended with **bilingual (English / Chinese) spell support**.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate --schema ./prisma-rules-clean/schema.prisma && prisma generate --schema ./prisma-content/schema.prisma && prisma generate --schema ./prisma-app-state/schema.prisma",
    "db:content:reset": "tsx scripts/ensure-sqlite-file.ts CONTENT_DATABASE_URL && prisma migrate dev --name init --config ./prisma-content/prisma.config.ts",
    "db:app-state:reset": "tsx scripts/ensure-sqlite-file.ts APP_STATE_DATABASE_URL && prisma migrate dev --name init --config ./prisma-app-state/prisma.config.ts",
    "db:app-state:seed": "prisma db seed --config ./prisma-app-state/prisma.config.ts",
    "db:content:import:zh-chm": "tsx scripts/import-zh-chm.ts",
    "db:content:import:zh-entities": "tsx scripts/import-zh-entities.ts",
    "db:app:reset": "npm run db:content:reset",
    "db:app:import:zh-chm": "npm run db:content:import:zh-chm",
    "db:app:import:zh-entities": "npm run db:content:import:zh-entities",
    "db:studio": "prisma studio",
    "test": "cross-env NODE_ENV=test vitest",
    "test:watch": "cross-env NODE_ENV=test vitest --watch",
    "tool:parse:test": "npm run -w data-tools zh:parse:test",
    "tool:parse": "npm run -w data-tools zh:parse",
    "tool:backcheck-zh": "npm run -w data-tools zh:backcheck",
    "tool:inspect-rules": "npm run -w data-tools inspect:rules",
    "tool:preprocess-zh": "npm run -w data-tools zh:preprocess"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd/contracts": "0.0.1",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.3",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "sanitize-html": "^2.17.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
