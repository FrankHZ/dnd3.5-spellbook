{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    // "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "esModuleInterop": true,
    "types": ["vitest/globals"],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "outDir": "dist",
    "sourceMap": true,
    "declaration": false,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": false,
    "importsNotUsedAsValues": "remove",
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "~/*": ["./src/*"],
      "prisma-rules-clean/*": ["./prisma-rules-clean/*"],
      "prisma-content/*": ["./prisma-content/*"],
      "prisma-app-state/*": ["./prisma-app-state/*"],
      "DB_RULES/*": ["./prisma-rules-clean/generated/*"],
      "DB_CONTENT/*": ["./prisma-content/generated/*"],
      "DB_APP_STATE/*": ["./prisma-app-state/generated/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "prisma-*/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
