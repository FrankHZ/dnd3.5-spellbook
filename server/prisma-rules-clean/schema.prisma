  dnd_characterclassvariant     dnd_characterclassvariant[]     @ignore
  dnd_racefavoredcharacterclass dnd_racefavoredcharacterclass[] @ignore
  spellClasslevels              SpellClasslevel[]
  spellClassIndexes             SpellClassIndex[]

  @@index([name], map: "dnd_characterclass_dnd_characterclass_name")
  @@index([slug], map: "dnd_characterclass_dnd_characterclass_a951d5d6")
  @@index([slug], map: "dnd_characterclass_dnd_characterclass_slug_uniq")
