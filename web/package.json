{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest",
    "typecheck": "react-router typegen && tsc",
    "i18n:sync": "node --experimental-strip-types ./scripts/i18next-sync.ts",
    "i18n:check": "node --experimental-strip-types ./scripts/i18next-sync.ts --check",
    "i18n:extract": "i18next-cli extract",
    "i18n:diff": "pwsh -Command \"$out='extracted/i18next.diff'; New-Item -ItemType Directory -Force -Path 'extracted' | Out-Null; git diff --no-index -- extracted public/locales | Out-File -Encoding utf8 $out; if ($LASTEXITCODE -eq 1) { exit 0 } else { exit $LASTEXITCODE }\"",
    "i18next:sync": "npm run i18n:sync",
    "i18next:sync:check": "npm run i18n:check",
    "i18next:extract": "npm run i18n:extract",
    "i18next:diff": "npm run i18n:diff"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@dnd/contracts": "0.0.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "7.18.0",
    "@react-router/serve": "7.18.0",
    "@tanstack/react-query": "^5.90.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.1",
    "i18next": "^25.8.1",
    "i18next-http-backend": "^3.0.2",
    "immer": "^11.1.4",
    "isbot": "^5.1.31",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router": "7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "use-immer": "^0.11.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.18.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "i18next-cli": "^1.41.4",
    "prettier": "3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
