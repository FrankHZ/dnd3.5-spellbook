generator client {
    provider = "prisma-client"
    output   = "../prisma-app-state/generated"
}

datasource db {
    provider = "sqlite"
}

model User {
    id        String   @id @default(cuid())
    email     String?  @unique
    createdAt DateTime @default(now())

    favorites FavoriteSpell[]
    notes     SpellNote[]
}

model FavoriteSpell {
    userId  String
    spellId Int

    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([userId, spellId])
    @@index([spellId])
}

model SpellNote {
    id      String @id @default(cuid())
    userId  String
    spellId Int

    note      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, spellId])
    @@index([spellId])
}
