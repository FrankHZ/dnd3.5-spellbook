{
  "name": "dnd3.5-spellbook-server",
  "version": "1.0.0",
  "description": "A modern **Dungeons & Dragons 3.5 spellbook web application** built with a **React + Express** stack, powered by a legacy SQLite dataset and extended with **bilingual (English / Chinese) spell support**.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate --schema ./prisma-rules-clean/schema.prisma",
    "prisma:studio": "prisma studio",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "tool:parse:test": "tsx src/tools/zh-parser/cli.ts --input ./data/chm-test/ --outDir out/zh-parser/test",
    "tool:parse": "tsx src/tools/zh-parser/cli.ts --input ./data/chm-clean/ --outDir out/zh-parser",
    "tool:backcheck-zh": "tsx src/tools/zh-parser/scripts/zh-backcheck.ts ./out/zh-parser/matched.json ./out/zh-parser/missing-zh.json",
    "tool:preprocess-zh": "tsx src/tools/zh-parser/scripts/preprocess-chm-html.ts --in ./data/chm-raw --out ./data/chm-clean"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd/contracts": "0.0.1",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
