generator client {
  provider     = "prisma-client"
  output       = "../prisma-rules-clean/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Rulebook {
  id                Int                 @id @map("id")
  dndEditionId      Int                 @map("dnd_edition_id")
  name              String              @map("name")
  abbr              String              @map("abbr")
  description       String              @map("description")
  year              String?             @map("year")
  officialUrl       String              @map("official_url")
  slug              String              @map("slug")
  image             String?             @map("image")
  published         DateTime?           @map("published")
  edition           Edition             @relation(fields: [dndEditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  spells            Spell[]
  dndFeats          dnd_feat[]          @ignore
  dndItems          dnd_item[]          @ignore
  dndDomainvariants dnd_domainvariant[] @ignore
  dndRaces          dnd_race[]          @ignore
  dndMonsters       dnd_monster[]       @ignore
  dndRules          dnd_rule[]          @ignore
  dndSkillvariants  dnd_skillvariant[]  @ignore

  dndCharacterclassvariants dnd_characterclassvariant[] @ignore
  spellClassIndexes         SpellClassIndex[]
  spellDomainIndexes        SpellDomainIndex[]

  @@index([name], map: "dnd_rulebook_dnd_rulebook_name")
  @@index([slug], map: "dnd_rulebook_dnd_rulebook_a951d5d6")
  @@index([dndEditionId], map: "dnd_rulebook_dnd_rulebook_66a88bda")
  @@index([slug], map: "dnd_rulebook_dnd_rulebook_slug_uniq")
  @@map("dnd_rulebook")
}

model Edition {
  id                 Int                @id @map("id")
  name               String             @map("name")
  system             String             @map("system")
  slug               String             @map("slug")
  core               Boolean            @map("core")
  rulebooks          Rulebook[]
  spellClassIndexes  SpellClassIndex[]
  spellDomainIndexes SpellDomainIndex[]

  @@index([name], map: "dnd_dndedition_dnd_dndedition_name")
  @@index([slug], map: "dnd_dndedition_dnd_dndedition_a951d5d6")
  @@index([slug], map: "dnd_dndedition_dnd_dndedition_slug_uniq")
  @@map("dnd_dndedition")
}

model CharacterClass {
  id                            Int                             @id
  name                          String
  slug                          String
  prestige                      Boolean                         @default(dbgenerated("'0'"))
