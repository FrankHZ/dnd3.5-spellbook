{
  "name": "dnd-spellbook",
  "private": true,
  "workspaces": [
    "server",
    "web",
    "contracts"
  ],
  "scripts": {
    "build:contracts": "npm run -w @dnd/contracts build",
    "build:server": "npm run -w server build",
    "build:web": "npm run -w web build",
    "test:server": "npm run -w server test -- --run",
    "typecheck:web": "npm run -w web typecheck",
    "verify": "npm run build:contracts && npm run test:server && npm run typecheck:web"
  },
  "dependencies": {
    "i18next-http-backend": "^3.0.2"
  }
}
