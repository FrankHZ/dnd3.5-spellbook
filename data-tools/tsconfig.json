{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "..",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "esnext",
    "esModuleInterop": true,
    "declaration": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "DATA/*": ["../data/*"],
      "prisma-rules-clean/*": ["../server/prisma-rules-clean/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
