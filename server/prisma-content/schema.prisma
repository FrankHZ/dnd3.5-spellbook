generator client {
    provider = "prisma-client"
    output   = "../prisma-content/generated"
}

datasource db {
    provider = "sqlite"
}

/// App-owned generated/imported content overlays.
/// User/app-state models belong to ../prisma-app-state/schema.prisma.
model I18nSpellText {
    id         String @id @default(cuid())
    spellId    Int
    rulebookId Int
    lang       String
    variant    String @default("default")

    name            String?
    descriptionHtml String?
    descriptionText String?

    sourceKey String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([spellId, lang, variant])
    @@index([lang, variant, rulebookId])
    @@index([lang, rulebookId])
    @@index([rulebookId, spellId])
}

model I18nSpellSummaryText {
    id         String @id @default(cuid())
    spellId    Int
    rulebookId Int
    lang       String
    variant    String @default("default")

    summaryText String
    sourceKey   String?
    sourceName  String?
    sourceKind  String?

    reviewStatus String @default("accepted")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([spellId, lang, variant])
    @@index([lang, variant, rulebookId])
    @@index([lang, rulebookId])
    @@index([rulebookId, spellId])
}

model I18nSpellNameAlias {
    id         String  @id @default(cuid())
    spellId    Int
    rulebookId Int
    lang       String
    aliasName  String
    source     String  @default("import") // import | manual | ai
    note       String?

    createdAt DateTime @default(now())

    @@unique([spellId, lang, aliasName])
    @@index([lang, rulebookId])
    @@index([lang, rulebookId, aliasName])
    @@index([rulebookId, spellId])
}

model I18nCharacterClassText {
    id      String @id @default(cuid())
    classId Int
    lang    String // 'zh-chm', 'zh-ai', etc.
    variant String @default("default")

    name                 String?
    shortDescriptionText String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([classId, lang, variant])
    @@index([lang, classId])
    @@index([classId])
}

model I18nDomainText {
    id       String @id @default(cuid())
    domainId Int
    lang     String
    variant  String @default("default")

    name String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([domainId, lang, variant])
    @@index([lang, domainId])
    @@index([domainId])
}

model I18nSpellSchoolText {
    id       String @id @default(cuid())
    schoolId Int
    lang     String
    variant  String @default("default")

    name String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([schoolId, lang, variant])
    @@index([lang, schoolId])
    @@index([schoolId])
}

model I18nSpellSubschoolText {
    id          String @id @default(cuid())
    subschoolId Int
    lang        String
    variant     String @default("default")

    name String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([subschoolId, lang, variant])
    @@index([lang, subschoolId])
    @@index([subschoolId])
}

model I18nDescriptorText {
    id           String @id @default(cuid())
    descriptorId Int
    lang         String
    variant      String @default("default")

    name String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([descriptorId, lang, variant])
    @@index([lang, descriptorId])
    @@index([descriptorId])
}

model I18nRulebookText {
    id         String @id @default(cuid())
    rulebookId Int
    lang       String
    variant    String @default("default")

    name            String?
    descriptionText String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([rulebookId, lang, variant])
    @@index([lang, rulebookId])
    @@index([rulebookId])
}

model RulesContentBuild {
    id                  String   @id
    sourceKind          String   @default("rules-clean")
    sourceSha256        String?
    generatorVersion    String
    generatedAt         DateTime @default(now())
    spellCount          Int
    issueCount          Int
    parentRepoCommit    String?
    dataRepoCommit      String?
    rulesManifestSha256 String?
    rulesDbSha256       String?
    migrationSetSha256  String?
    buildMetaJson       String?

    @@index([sourceKind, generatedAt])
    @@index([parentRepoCommit])
    @@index([dataRepoCommit])
}

model RulebookContent {
    id               String @id
    legacyRulebookId Int    @unique
    editionId        Int
    name             String
    abbr             String
    slug             String
    displayName      String?
    displayAbbr      String?
    rawJson          String?

    @@index([editionId])
    @@index([slug])
}

model SpellContent {
    id               String @id
    legacySpellId    Int    @unique
    canonicalName    String
    slug             String
    sourceRulebookId Int
    sourcePage       Int?
    schoolRaw        String?
    subschoolRaw     String?
    castingTimeRaw   String?
    rangeRaw         String?
    targetRaw        String?
    effectRaw        String?
    areaRaw          String?
    durationRaw      String?
    savingThrowRaw   String?
    resistanceRaw    String?
    componentsRaw    String?
    corruptLevel     Int?
    descriptionText  String
    descriptionHtml  String?
    descriptionHash  String
    addedAt          DateTime
    verified         Boolean @default(false)
    verifiedAuthorId Int?
    verifiedTime     DateTime?
    rawJson          String?

    @@index([canonicalName])
    @@index([slug])
    @@index([sourceRulebookId])
}

model SpellAppearance {
    id               String  @id
    spellId          String
    legacySpellId    Int
    rulebookId       Int
    page             Int?
    printedName      String
    sourceSlug       String
    sourceKey        String?
    sourceNote       String?

    @@unique([legacySpellId, rulebookId, printedName])
    @@index([spellId])
    @@index([rulebookId])
}

model SpellTaxonomyFacet {
    id            String  @id
    spellId       String
    facetType     String
    facetKey      String
    legacyFacetId Int?
    name          String
    slug          String?
    sortOrder     Int     @default(0)
    rawText       String?
    sourceField   String
    reviewStatus  String  @default("accepted")
    issueCode     String?

    @@unique([spellId, facetType, facetKey, sortOrder])
    @@index([facetType, facetKey])
    @@index([spellId])
}

model SpellListEntry {
    id            String  @id
    spellId       String
    listType      String
    ownerLegacyId Int
    ownerName     String
    ownerSlug     String
    ownerPrestige Boolean?
    level         Int
    rulebookId    Int?
    rawExtra      String?
    variantLabel  String?
    note          String?
    sourceRowId   Int?
    sourceTable   String
    reviewStatus  String  @default("accepted")
    issueCode     String?

    @@index([listType, ownerLegacyId, level])
    @@index([spellId])
    @@index([rulebookId])
}

model SpellComponent {
    id            String  @id
    spellId       String
    componentType String
    present       Boolean
    rawText       String?
    detailText    String?
    sourceField   String
    reviewStatus  String  @default("accepted")
    issueCode     String?

    @@unique([spellId, componentType, sourceField])
    @@index([componentType, present])
    @@index([spellId])
}

model SpellMechanicFacet {
    id           String  @id
    spellId      String
    mechanicType String
    rawText      String?
    category     String
    amount       Int?
    unit         String?
    flagsJson    String?
    sourceField  String
    reviewStatus String  @default("accepted")
    issueCode    String?

    @@unique([spellId, mechanicType])
    @@index([mechanicType, category])
    @@index([spellId])
}

model RulesContentIssue {
    id          String  @id
    spellId     String?
    sourceTable String
    sourceField String
    rawText     String?
    issueCode   String
    severity    String
    detail      String?

    @@index([issueCode])
    @@index([severity])
    @@index([spellId])
}
