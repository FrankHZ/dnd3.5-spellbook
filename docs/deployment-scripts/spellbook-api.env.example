# Example /etc/default/spellbook-api for the v1.0 backend API deployment.
# Copy values intentionally; do not store secrets in this file.

NODE_ENV=production
PORT=3000
HOST=127.0.0.1

RULES_DATABASE_URL=file:/opt/spellbook/data/spellbook.db
CONTENT_DATABASE_URL=file:/opt/spellbook/data/content.sqlite
APP_DATABASE_URL=file:/opt/spellbook/data/content.sqlite
APP_STATE_DATABASE_URL=file:/opt/spellbook/data/app-state.sqlite
DATABASE_URL=file:/opt/spellbook/data/spellbook.db

# Default normalized content reads use CONTENT_DATABASE_URL.
# Uncomment only as a rollback to the legacy rules-backed read path.
# SPELL_READ_SOURCE=rules

# Production CORS is explicit. Set this for trusted frontend origins that call
# the API from Cloudflare Workers.
SPELLBOOK_CORS_ORIGINS=https://d20spellcodex.com,https://www.d20spellcodex.com

# Optional deploy metadata exposed by GET /api/status/app and the About page.
# GitHub deploy refreshes these automatically for normal backend deploys.
SPELLBOOK_VERSION_LABEL=v1.0
SPELLBOOK_BACKEND_COMMIT_SHA=
SPELLBOOK_BACKEND_SHORT_SHA=
SPELLBOOK_BACKEND_REF=
SPELLBOOK_BACKEND_DEPLOYED_AT=
SPELLBOOK_BACKEND_GITHUB_RUN_ID=
SPELLBOOK_BACKEND_GITHUB_RUN_ATTEMPT=

# GET /api/status/db is private by default in production because it reports
# runtime database provenance. Set a token for operator checks, then call with:
#   Authorization: Bearer <token>
# or:
#   X-Spellbook-Operations-Token: <token>
SPELLBOOK_DB_STATUS_TOKEN=

# Uncomment only if the DB provenance endpoint is intentionally public.
# ENABLE_DB_STATUS_PUBLIC=true
