{
  "name": "data-tools",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "inspect:rules": "tsx src/inspect-rules-db.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "zh:backcheck": "tsx src/zh-parser/scripts/zh-backcheck.ts ../server/out/zh-parser/matched.json ../server/out/zh-parser/missing-zh.json",
    "zh:parse": "tsx src/zh-parser/cli.ts --input ../server/data/chm-clean --outDir ../server/out/zh-parser",
    "zh:parse:test": "tsx src/zh-parser/cli.ts --input ../server/data/chm-test --outDir ../server/out/zh-parser/test",
    "zh:preprocess": "tsx src/zh-parser/scripts/preprocess-chm-html.ts --in ../server/data/chm-raw --out ../server/data/chm-clean"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "iconv-lite": "^0.7.2",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.9",
    "@types/sanitize-html": "^2.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
